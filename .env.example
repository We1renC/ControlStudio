# Copy this file to .env and fill in your real key.
# Do not commit the real .env file.
#
# NVIDIA_API_KEY is a shared NVIDIA API key for the account, not for one specific model.
# You can switch models at runtime with CLI flags or env defaults below.

NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_EMBED_MODEL=nvidia/nv-embed-v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-8b-instruct
